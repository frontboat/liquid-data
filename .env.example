# Anthropic API key (required)
ANTHROPIC_API_KEY=

# Model to use (optional, defaults to claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Password gate (optional — if not set, the app is publicly accessible)
AUTH_PASSWORD=
# Secret key for signing session tokens (required if AUTH_PASSWORD is set)
# Generate with: openssl rand -base64 32
AUTH_SECRET=
