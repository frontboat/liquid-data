# Vercel AI Gateway API key (required)
AI_GATEWAY_API_KEY=

# Model to use (optional, defaults to anthropic/claude-haiku-4.5)
# AI_GATEWAY_MODEL=anthropic/claude-sonnet-4-20250514

# Password gate (optional — if not set, the app is publicly accessible)
AUTH_PASSWORD=
# Secret key for signing session tokens (required if AUTH_PASSWORD is set)
# Generate with: openssl rand -base64 32
AUTH_SECRET=
